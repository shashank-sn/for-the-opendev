# site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=.data/fortheopen.db
ADMIN_EMAILS=you@example.com
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# oauth — create apps in google cloud + github developer settings
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# email — all mail via cloudflare (sending + routing). every message stored in sql (emails table)
# production: worker send_email binding in wrangler.jsonc (no api key needed)
# inbound: route *@fortheopen.dev to this worker (wrangler email routing rules create)
# local dev: optional REST fallback with account token + onboarded from-domain
EMAIL_FROM=noreply@fortheopen.dev
EMAIL_FROM_NAME=for the open dev
EMAIL_REPLY_TO=hello@fortheopen.dev
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# cloudflare d1 (production)
CLOUDFLARE_D1_DATABASE_ID=

# github sponsors webhook (optional)
GITHUB_SPONSORS_WEBHOOK_SECRET=

# analytics — self-hosted plausible (https://github.com/plausible/analytics)
# tracking script (public)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=fortheopen.dev
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://your-plausible-instance.example/js/script.js
# stats api (server only — never expose to client)
PLAUSIBLE_API_URL=https://your-plausible-instance.example
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=fortheopen.dev
# password-only login for /analytics dashboard
ANALYTICS_PASSWORD=
ANALYTICS_SESSION_SECRET=

# cron fallback auth (optional)
CRON_SECRET=