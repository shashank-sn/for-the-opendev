# site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=.data/fortheopen.db
ADMIN_EMAILS=you@example.com
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# oauth — create apps in google cloud + github developer settings
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# email (magic link) — smtp to self-hosted mail or oss provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@fortheopen.dev

# cloudflare d1 (production)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# github sponsors webhook (optional)
GITHUB_SPONSORS_WEBHOOK_SECRET=

# analytics (self-hosted umami or plausible)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=

# newsletter (self-hosted listmonk — public list uuid from listmonk admin)
LISTMONK_URL=
LISTMONK_LIST_UUID=

# cron fallback auth (optional)
CRON_SECRET=