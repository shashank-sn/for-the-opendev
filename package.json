{
  "name": "for-the-opendev",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @ftod/web dev",
    "build": "node scripts/generate-badges.mjs && pnpm --filter @ftod/web build && pnpm --filter @ftod/web pagefind",
    "lint": "pnpm -r lint",
    "content:generate": "node scripts/generate-content.mjs",
    "typecheck": "pnpm -r typecheck",
    "codegraph:init": "npx @colbymchenry/codegraph init -i",
    "codegraph:sync": "npx @colbymchenry/codegraph sync",
    "codegraph:status": "npx @colbymchenry/codegraph status",
    "codegraph:hooks": "node scripts/install-codegraph-hooks.mjs",
    "prepare": "node scripts/install-codegraph-hooks.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}