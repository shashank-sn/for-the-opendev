{
  "name": "for-the-opendev",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @ftod/web dev",
    "build": "pnpm --filter @ftod/web build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @ftod/db generate",
    "db:migrate": "pnpm --filter @ftod/db migrate",
    "content:generate": "node scripts/generate-content.mjs",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}