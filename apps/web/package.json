{
  "name": "@ftod/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "DATABASE_URL=../../.data/fortheopen.db BETTER_AUTH_URL=http://localhost:3000 BETTER_AUTH_SECRET=dev-local-secret-32-characters-min next dev",
    "build": "DATABASE_URL=../../.data/fortheopen.db BETTER_AUTH_URL=${BETTER_AUTH_URL:-http://localhost:3000} BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET:-dev-local-secret-32-characters-min} next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pagefind": "pagefind --site .next/server/app --output-path public/pagefind"
  },
  "dependencies": {
    "@ftod/auth": "workspace:*",
    "@ftod/db": "workspace:*",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.39.3",
    "@ftod/ui": "workspace:*",
    "better-auth": "^1.2.5",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "pagefind": "^1.3.0",
    "typescript": "^5.7.3"
  }
}